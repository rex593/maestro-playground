{
  "name": "maestro-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm catalog:build && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prebuild": "pnpm catalog:build",
    "catalog:build": "tsx bin/validate.ts build-catalog",
    "catalog:check": "tsx bin/validate.ts check-catalog",
    "validate:catalog": "tsx bin/validate.ts catalog",
    "validate:pathway": "tsx bin/validate.ts pathway",
    "drift:report": "tsx bin/validate.ts drift",
    "migrate:dry": "tsx bin/migrate.ts --dry-run",
    "migrate": "tsx bin/migrate.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "elkjs": "^0.9.3",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.0.7",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-resizable-panels": "^2.1.9",
    "react-window": "^1.8.10",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zundo": "^2.2.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.12.0",
    "postcss": "^8.5.15",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "engines": {
    "node": ">=20"
  }
}
